# GCMC Equilibration Step
# Reads from current_config.data and outputs gcmc_final.data
#


units real
atom_style full
boundary p p p

pair_style lj/cut 14.0
pair_modify mix arithmetic tail no
bond_style harmonic
angle_style harmonic
dihedral_style charmm
improper_style cvff

read_data ${rundir}/current_config.data

include paircoeffs.in

variable volume equal lx*ly*lz

group Zn1 type 1
group N1 type 2
group C type 3 4 5
group H type 6 7 8 9
group Ar type 10
group MOF type 1 2 3 4 5 6 7 8 9

mass 10 39.948

fix recenter MOF recenter INIT INIT INIT

# Store initial state before GCMC starts
run 0

# Write initial values to separate files (one value per file)
print "$(pe)" file ${rundir}/gcmc_u_init.txt
print "$(vol)" file ${rundir}/gcmc_v_init.txt

# Read initial values from separate files
variable u_init_read file ${rundir}/gcmc_u_init.txt
variable v_init_read file ${rundir}/gcmc_v_init.txt

variable u_init internal ${u_init_read}
variable v_init internal ${v_init_read}

variable p_target equal ${p}

# Conversion factor
variable kb equal 0.001987204
variable atm_to_kcal equal 1.4584e-5

# Store initial particle count
variable n_init equal count(Ar)

# GCMC fix
fix gcmc Ar gcmc 1 2 1 10 ${iter} ${Tsim} 0 0.1 pressure ${p} fugacity_coeff ${phi}

thermo_style custom step atoms lx ly lz v_volume temp pxx pyy pzz press pe ke etotal enthalpy
thermo 10

run ${gcmc_steps}

unfix gcmc

# Extract final state (end of GCMC; NVT relaxation now happens in nvt_step.in)
variable u_final equal pe
variable v_final equal vol
variable p_final equal press
variable n_final equal count(Ar)

# Calculate DG for GCMC using target pressure
# For muVT ensemble: DG = DU + P_target*DV - mu*DN
variable du_final equal v_u_final-v_u_init
variable dv_final equal v_v_final-v_v_init
variable dn_final equal v_n_final-v_n_init
variable mu equal v_kb*${Tsim}*ln(v_p_target*${phi})
variable delta_g_final equal v_du_final+v_p_target*v_dv_final*v_atm_to_kcal-v_mu*v_dn_final

print "${u_final} ${v_final} ${p_final} ${delta_g_final}" file ${rundir}/gcmc_final_state.txt

write_data ${rundir}/gcmc_final.data

unfix recenter